rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Members are managed by staff only. There is no public sign-up in this
    // app — accounts are created manually in the Firebase Auth console, so
    // any authenticated user is trusted staff.
    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }

    // Shared counter used to assign sequential card numbers.
    match /meta/counters {
      allow read, write: if request.auth != null;
    }

    // App-wide settings (e.g. the extendable membership fee year range).
    match /meta/settings {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
